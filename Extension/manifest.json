{
  "manifest_version": 3,
  "name": "DuoSign — Text to Sign Language",
  "short_name": "DuoSign",
  "version": "1.0.0",
  "description": "Translate any text on the web into American Sign Language animations instantly.",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "DuoSign — Translate to Sign Language",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "activeTab",
    "storage",
    "contextMenus"
  ],

  "host_permissions": [
    "http://localhost:8000/*",
    "https://api.duosign.com/*"
  ],

  "commands": {
    "translate-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Translate selected text with DuoSign"
    }
  }
}
